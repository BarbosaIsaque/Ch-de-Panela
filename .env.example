# Copie este arquivo para ".env" e preencha com os valores reais.
# Os valores de produção estão no HANDOFF.md e na Vercel.
# NUNCA commitar o .env — ele está no .gitignore.

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Autenticação ──────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-longa
ADMIN_PASSWORD=

# ── E-mail OTP (Brevo) ────────────────────────────────────────
BREVO_API_KEY=
EMAIL_FROM=cha@isana.ia.br

# ── Pagamento — InfinitePay (Cartão/Débito) ───────────────────
INFINITEPAY_HANDLE=isaque-barbosa-dias

# ── Pagamento — AbacatePay (PIX dinâmico) ─────────────────────
# Usar chave "abc_dev_*" para testes; trocar pela de produção antes do evento
ABACATEPAY_API_KEY=
ABACATEPAY_WEBHOOK_SECRET=

# ── URL pública ───────────────────────────────────────────────
# Em produção: https://cha.isana.ia.br
# Em local:    http://localhost:3000
SITE_URL=http://localhost:3000
